{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://miyagawa.local/brain-cognitive-architecture-jp/edge.schema.json",
  "title": "Brain Cognitive Architecture — Typed relation edge",
  "description": "正本は event log。memory/edge は派生 snapshot の要素。本ファイルは scripts/brain_architecture/schemas.py と同期（tests/unit/test_schemas_sync.py が検証）。",
  "type": "object",
  "required": [
    "edge_id",
    "source",
    "target",
    "relation",
    "scope"
  ],
  "properties": {
    "edge_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "relation": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "symmetric",
        "directed"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "session",
        "task",
        "project",
        "client",
        "organization",
        "user",
        "machine",
        "global"
      ]
    },
    "raw": {
      "type": "object"
    },
    "derived": {
      "type": "object"
    },
    "status": {
      "type": "string"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
