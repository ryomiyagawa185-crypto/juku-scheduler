{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://miyagawa.local/brain-cognitive-architecture-jp/policy.schema.json",
  "title": "Brain Cognitive Architecture — Policy candidate",
  "description": "正本は event log。memory/edge は派生 snapshot の要素。本ファイルは scripts/brain_architecture/schemas.py と同期（tests/unit/test_schemas_sync.py が検証）。",
  "type": "object",
  "required": [
    "candidate_id",
    "description"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string",
      "enum": [
        "session",
        "task",
        "project",
        "client",
        "organization",
        "user",
        "machine",
        "global"
      ]
    },
    "criteria": {
      "type": "object"
    },
    "reversible": {
      "type": "boolean"
    },
    "requires_approval": {
      "type": "boolean"
    }
  }
}
