{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://miyagawa.local/mac-neural-grid/node.schema.json",
  "title": "mac-neural-grid — Node",
  "description": "src/mac_neural_grid/schemas.py と同期（tests が検証）。",
  "type": "object",
  "required": [
    "node_id",
    "display_name",
    "host",
    "transport",
    "trust"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "user": {
      "type": [
        "string",
        "null"
      ]
    },
    "transport": {
      "type": "string",
      "enum": [
        "local",
        "ssh"
      ]
    },
    "trust": {
      "type": "string",
      "enum": [
        "untrusted",
        "low",
        "medium",
        "high"
      ]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "work_root": {
      "type": [
        "string",
        "null"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "host_key_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "capabilities": {
      "type": "object"
    },
    "current_load": {
      "type": "object"
    },
    "last_heartbeat": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
